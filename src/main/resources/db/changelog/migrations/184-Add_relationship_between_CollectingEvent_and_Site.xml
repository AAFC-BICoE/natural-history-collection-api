<?xml version="1.1" encoding="UTF-8" standalone="no" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://local.xsd/dbchangelog-4.4.xsd"
                   objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="184-Add_relationship_between_CollectingEvent_and_Site" context="schema-change" author="pyalamanchli">
        <addColumn tableName="collecting_event">
            <column name="site_id" type="integer">
                <constraints foreignKeyName="fk_site_id" references="site(id)"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>